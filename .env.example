# Secret key Flask uses to sign session cookies. Generate one with:
# python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace-with-a-random-hex-string

# Stripe test secret key, from https://dashboard.stripe.com/test/apikeys
# Starts with sk_test_ for test mode. Never use a live (sk_live_) key here.
STRIPE_SECRET_KEY=sk_test_replace_with_your_own_key

# Base URL the app redirects Stripe back to after checkout.
YOUR_DOMAIN=http://127.0.0.1:5000
